let x: Float = 384.0
let y: Float = 284.0
const SPEED: Float = 200.0

fn update(dt: Float)
    if key_down("right")
        x += SPEED * dt
    if key_down("left")
        x -= SPEED * dt
    if key_down("down")
        y += SPEED * dt
    if key_down("up")
        y -= SPEED * dt

fn draw()
    draw_rect(x, y, 32.0, 32.0)
