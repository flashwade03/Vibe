let cells: List[Float] = []

fn load()
    for i in range(0, 48)
        cells = cells + [0.0]

fn mousepressed(mx: Float, my: Float, button: Int)
    let col: Int = int((mx - 40.0) / 80.0)
    let row: Int = int((my - 60.0) / 80.0)
    if col >= 0 and col < 8 and row >= 0 and row < 6
        let idx: Int = row * 8 + col
        if cells[idx] == 0.0
            cells[idx] = 1.0
        else
            cells[idx] = 0.0

fn draw()
    for row in range(0, 6)
        for col in range(0, 8)
            let x: Float = 40.0 + float(col) * 80.0
            let y: Float = 60.0 + float(row) * 80.0
            draw_rect(x, y, 80.0, 80.0)
            if cells[row * 8 + col] == 1.0
                draw_rect(x + 4.0, y + 4.0, 72.0, 72.0)
    let count: Int = 0
    for i in range(0, 48)
        if cells[i] == 1.0
            count = count + 1
    draw_text("Active: " + str(count), 10.0, 10.0)
