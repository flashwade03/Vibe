let wp_xs: List[Float] = [100.0, 700.0, 700.0, 100.0]
let wp_ys: List[Float] = [100.0, 100.0, 500.0, 500.0]
let patrol_x: Float = 100.0
let patrol_y: Float = 100.0
let current_wp: Int = 1
let patrol_speed: Float = 120.0

fn update(dt: Float)
    let dx: Float = wp_xs[current_wp] - patrol_x
    let dy: Float = wp_ys[current_wp] - patrol_y
    let dist: Float = sqrt(dx * dx + dy * dy)
    if dist > 2.0
        patrol_x = patrol_x + (dx / dist) * patrol_speed * dt
        patrol_y = patrol_y + (dy / dist) * patrol_speed * dt
    else
        current_wp = current_wp + 1
        if current_wp >= 4
            current_wp = 0

fn draw()
    draw_rect(patrol_x - 12.0, patrol_y - 12.0, 24.0, 24.0)
    for i in range(0, 4)
        draw_rect(wp_xs[i] - 4.0, wp_ys[i] - 4.0, 8.0, 8.0)
    draw_text("Waypoint: " + str(current_wp), 10.0, 10.0)
