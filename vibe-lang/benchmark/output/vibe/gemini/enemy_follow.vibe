let px: Float = 400.0
let py: Float = 300.0
let ex: Float = 100.0
let ey: Float = 100.0
let p_speed: Float = 200.0
let e_speed: Float = 100.0

fn update(dt: Float)
    if key_down("right")
        px += p_speed * dt
    if key_down("left")
        px -= p_speed * dt
    if key_down("down")
        py += p_speed * dt
    if key_down("up")
        py -= p_speed * dt

    let dx: Float = px - ex
    let dy: Float = py - ey
    let dist: Float = sqrt(dx * dx + dy * dy)

    if dist > 1.0
        ex += (dx / dist) * e_speed * dt
        ey += (dy / dist) * e_speed * dt

fn draw()
    -- Enemy (Red)
    draw_rect(ex, ey, 32, 32, 255, 0)
    -- Player (Blue)
    draw_rect(px, py, 32, 32, 0, 255)
