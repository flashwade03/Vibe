let player_x: Float = 1000.0
let player_y: Float = 1000.0
let item_xs: List[Float] = []
let item_ys: List[Float] = []
let initialized: Bool = false

fn load()
    for i in range(0, 20)
        item_xs = item_xs + [rand_float(0.0, 2000.0)]
        item_ys = item_ys + [rand_float(0.0, 2000.0)]
    initialized = true

fn update(dt: Float)
    if not initialized
        load()

    let speed: Float = 300.0
    if key_down("right")
        player_x += speed * dt
    if key_down("left")
        player_x -= speed * dt
    if key_down("down")
        player_y += speed * dt
    if key_down("up")
        player_y -= speed * dt

fn draw()
    -- Main view items
    for i in range(0, len(item_xs))
        let draw_x = item_xs[i] - (player_x - 400.0)
        let draw_y = item_ys[i] - (player_y - 300.0)
        if draw_x > -20.0 and draw_x < 820.0 and draw_y > -20.0 and draw_y < 620.0
            draw_rect(draw_x, draw_y, 10.0, 10.0)

    -- Player in main view
    draw_rect(400.0 - 8.0, 300.0 - 8.0, 16.0, 16.0)

    -- Minimap
    draw_rect(630.0, 10.0, 160.0, 120.0)
    for i in range(0, len(item_xs))
        let mx = 630.0 + (item_xs[i] / 2000.0) * 160.0
        let my = 10.0 + (item_ys[i] / 2000.0) * 120.0
        draw_rect(mx, my, 2.0, 2.0)

    let px = 630.0 + (player_x / 2000.0) * 160.0
    let py = 10.0 + (player_y / 2000.0) * 120.0
    draw_rect(px - 1.0, py - 1.0, 2.0, 2.0)

    -- UI
    draw_text("Pos: " + str(int(player_x)) + ", " + str(int(player_y)), 10.0, 10.0)
