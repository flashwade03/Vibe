let frame: Int = 0
let frame_timer: Float = 0.0

fn update(dt: Float)
    frame_timer += dt
    if frame_timer >= 0.25
        frame_timer -= 0.25
        frame += 1

    if frame >= 4
        frame = 0

fn draw()
    if frame == 0
        draw_rect(380.0, 280.0, 40.0, 40.0)
    else if frame == 1
        draw_rect(375.0, 275.0, 50.0, 50.0)
    else if frame == 2
        draw_rect(370.0, 270.0, 60.0, 60.0)
    else if frame == 3
        draw_rect(375.0, 275.0, 50.0, 50.0)

    draw_text("Frame: " + str(frame), 10.0, 10.0)
