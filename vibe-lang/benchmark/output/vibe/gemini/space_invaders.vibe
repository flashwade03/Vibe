let inv_xs: List[Float] = []
let inv_ys: List[Float] = []
let inv_alive: List[Float] = []
let inv_dir: Float = 1.0
let inv_speed: Float = 40.0
let px: Float = 384.0
let bul_xs: List[Float] = []
let bul_ys: List[Float] = []
let bul_alive: List[Float] = []
let score: Int = 0
let initialized: Bool = false

fn load()
    for row in range(0, 3)
        for col in range(0, 6)
            inv_xs = inv_xs + [150.0 + float(col) * 80.0]
            inv_ys = inv_ys + [50.0 + float(row) * 50.0]
            inv_alive = inv_alive + [1.0]

fn keypressed(k: String)
    if k == "space"
        bul_xs = bul_xs + [px + 14.0]
        bul_ys = bul_ys + [540.0]
        bul_alive = bul_alive + [1.0]

fn update(dt: Float)
    if not initialized
        load()
        initialized = true

    if key_down("left")
        px -= 250.0 * dt
    if key_down("right")
        px += 250.0 * dt

    if px < 0.0
        px = 0.0
    if px > 768.0
        px = 768.0

    let reverse: Bool = false
    for i in range(0, len(inv_xs))
        if inv_alive[i] == 1.0
            inv_xs[i] += inv_speed * inv_dir * dt
            if inv_xs[i] < 20.0 or inv_xs[i] > 750.0
                reverse = true

    if reverse
        inv_dir = -inv_dir
        for i in range(0, len(inv_ys))
            if inv_alive[i] == 1.0
                inv_ys[i] += 20.0

    for j in range(0, len(bul_ys))
        if bul_alive[j] == 1.0
            bul_ys[j] -= 400.0 * dt
            if bul_ys[j] < 0.0
                bul_alive[j] = 0.0

    for j in range(0, len(bul_xs))
        if bul_alive[j] == 1.0
            for i in range(0, len(inv_xs))
                if inv_alive[i] == 1.0 and bul_xs[j] >= inv_xs[i] and bul_xs[j] <= inv_xs[i] + 30.0 and bul_ys[j] >= inv_ys[i] and bul_ys[j] <= inv_ys[i] + 20.0
                    inv_alive[i] = 0.0
                    bul_alive[j] = 0.0
                    score += 1

fn draw()
    draw_rect(px, 550.0, 32.0, 16.0)
    for i in range(0, len(inv_xs))
        if inv_alive[i] == 1.0
            draw_rect(inv_xs[i], inv_ys[i], 30.0, 20.0)
    for j in range(0, len(bul_xs))
        if bul_alive[j] == 1.0
            draw_rect(bul_xs[j], bul_ys[j], 4.0, 10.0)

    draw_text("Score: " + str(score), 10.0, 10.0)

    let alive: Int = 0
    for i in range(0, len(inv_alive))
        if inv_alive[i] == 1.0
            alive += 1
    if alive == 0
        draw_text("YOU WIN!", 340.0, 280.0)
