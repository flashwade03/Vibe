let px: Float = 400.0
let py: Float = 300.0
let speed: Float = 300.0
let spawn_timer: Float = 0.3
let survived_time: Float = 0.0
let hit: Bool = false

let bx: List[Float] = []
let by: List[Float] = []
let bvx: List[Float] = []
let bvy: List[Float] = []
let blife: List[Float] = []

fn update(dt: Float)
    if not hit
        survived_time += dt

        if key_down("right")
            px += speed * dt
        if key_down("left")
            px -= speed * dt
        if key_down("up")
            py -= speed * dt
        if key_down("down")
            py += speed * dt

        spawn_timer -= dt
        if spawn_timer <= 0.0
            spawn_timer = 0.3
            let side = rand_float(0.0, 4.0)
            let sx: Float = 0.0
            let sy: Float = 0.0
            if side < 1.0
                sx = rand_float(0.0, 800.0)
                sy = 0.0
            else if side < 2.0
                sx = 800.0
                sy = rand_float(0.0, 600.0)
            else if side < 3.0
                sx = rand_float(0.0, 800.0)
                sy = 600.0
            else
                sx = 0.0
                sy = rand_float(0.0, 600.0)

            let dx = px - sx
            let dy = py - sy
            let dist = sqrt(dx * dx + dy * dy)
            bx += [sx]
            by += [sy]
            bvx += [dx / dist * 250.0]
            bvy += [dy / dist * 250.0]
            blife += [4.0]

        for i in range(0, len(bx))
            if blife[i] > 0.0
                bx[i] += bvx[i] * dt
                by[i] += bvy[i] * dt
                blife[i] -= dt
                let dist = sqrt((px - bx[i]) * (px - bx[i]) + (py - by[i]) * (py - by[i]))
                if dist < 13.0
                    hit = true

fn draw()
    draw_circle(px, py, 10.0)
    for i in range(0, len(bx))
        if blife[i] > 0.0
            draw_rect(bx[i] - 3.0, by[i] - 3.0, 6.0, 6.0)

    if hit
        draw_text("HIT! Time: " + str(int(survived_time)), 350.0, 300.0)
    else
        draw_text("Time: " + str(int(survived_time)), 10.0, 10.0)
