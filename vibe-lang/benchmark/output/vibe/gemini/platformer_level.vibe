let px: Float = 100.0
let py: Float = 400.0
let vx: Float = 0.0
let vy: Float = 0.0
let on_ground: Bool = false

let plat_xs: List[Float] = [50.0, 300.0, 500.0, 200.0, 450.0]
let plat_ys: List[Float] = [450.0, 380.0, 300.0, 220.0, 150.0]
let plat_ws: List[Float] = [200.0, 150.0, 180.0, 120.0, 200.0]

fn update(dt: Float)
    let prev_y: Float = py

    if key_down("left")
        vx = -250.0
    else if key_down("right")
        vx = 250.0
    else
        vx = 0.0

    if key_down("up") and on_ground
        vy = -350.0
        on_ground = false

    vy += 600.0 * dt
    px += vx * dt
    py += vy * dt

    on_ground = false

    -- Platform collision
    for i in range(0, len(plat_xs))
        if vy >= 0.0 and prev_y + 20.0 <= plat_ys[i]
            if py + 20.0 >= plat_ys[i] and px + 20.0 > plat_xs[i] and px < plat_xs[i] + plat_ws[i]
                py = plat_ys[i] - 20.0
                vy = 0.0
                on_ground = true

    -- Ground collision
    if py + 20.0 >= 580.0
        py = 560.0
        vy = 0.0
        on_ground = true

    -- Reset
    if py > 620.0
        px = 100.0
        py = 400.0
        vy = 0.0

fn draw()
    draw_text("Use arrows + up to jump", 10.0, 10.0)
    draw_rect(px, py, 20.0, 20.0)

    for i in range(0, len(plat_xs))
        draw_rect(plat_xs[i], plat_ys[i], plat_ws[i], 12.0)

    draw_rect(0.0, 580.0, 800.0, 20.0)
