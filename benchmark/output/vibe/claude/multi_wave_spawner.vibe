-- Multi-Wave Spawner: enemies spawn in waves, each wave has more enemies
let wave: Int = 0
let wave_timer: Float = 2.0
let enemies_this_wave: Int = 3

let ex: List[Float] = []
let ey: List[Float] = []
let evx: List[Float] = []
let evy: List[Float] = []
let alive: List[Float] = []

let score: Int = 0

fn update(dt: Float)
    -- Wave spawning timer
    wave_timer = wave_timer - dt
    if wave_timer <= 0.0
        wave = wave + 1
        enemies_this_wave = 2 + wave
        wave_timer = 3.0
        -- Spawn enemies from random edges
        for s in range(0, enemies_this_wave)
            let edge: Float = rand_float(0.0, 4.0)
            let sx: Float = 0.0
            let sy: Float = 0.0
            let vx: Float = 0.0
            let vy: Float = 0.0
            let spd: Float = 60.0 + float(wave) * 15.0
            if edge < 1.0
                sx = rand_float(0.0, 800.0)
                sy = -10.0
                vx = rand_float(-50.0, 50.0)
                vy = spd
            else if edge < 2.0
                sx = 810.0
                sy = rand_float(0.0, 600.0)
                vx = -spd
                vy = rand_float(-50.0, 50.0)
            else if edge < 3.0
                sx = rand_float(0.0, 800.0)
                sy = 610.0
                vx = rand_float(-50.0, 50.0)
                vy = -spd
            else
                sx = -10.0
                sy = rand_float(0.0, 600.0)
                vx = spd
                vy = rand_float(-50.0, 50.0)
            ex = ex + [sx]
            ey = ey + [sy]
            evx = evx + [vx]
            evy = evy + [vy]
            alive = alive + [1.0]

    -- Move enemies
    for i in range(0, len(ex))
        if alive[i] > 0.0
            ex[i] = ex[i] + evx[i] * dt
            ey[i] = ey[i] + evy[i] * dt
            -- Deactivate if far off screen
            if ex[i] < -50.0 or ex[i] > 850.0 or ey[i] < -50.0 or ey[i] > 650.0
                alive[i] = 0.0

fn draw()
    -- Draw enemies
    for i in range(0, len(ex))
        if alive[i] > 0.0
            draw_rect(ex[i] - 8.0, ey[i] - 8.0, 16.0, 16.0)
    -- HUD
    draw_text("Wave: " + str(wave), 10.0, 10.0)
    draw_text("Next wave in: " + str(int(wave_timer)), 10.0, 35.0)
