let player_x: Float = 400.0
let player_y: Float = 300.0
let player_speed: Float = 250.0
let wave: Int = 1
let spawn_timer: Float = 2.0
let enemies_per_wave: Int = 3
let game_over: Bool = false
let ex: List[Float] = []
let ey: List[Float] = []
let evx: List[Float] = []
let evy: List[Float] = []
let elife: List[Float] = []

fn update(dt: Float)
    if game_over
        return
    if key_down("right")
        player_x = player_x + player_speed * dt
    if key_down("left")
        player_x = player_x - player_speed * dt
    if key_down("down")
        player_y = player_y + player_speed * dt
    if key_down("up")
        player_y = player_y - player_speed * dt
    spawn_timer = spawn_timer - dt
    if spawn_timer <= 0.0
        let spd: Float = float(80 + wave * 20)
        for j in range(0, enemies_per_wave)
            let edge: Float = rand_float(0.0, 4.0)
            let sx: Float = 0.0
            let sy: Float = 0.0
            if edge < 1.0
                sx = rand_float(0.0, 800.0)
                sy = 0.0
            else if edge < 2.0
                sx = 800.0
                sy = rand_float(0.0, 600.0)
            else if edge < 3.0
                sx = rand_float(0.0, 800.0)
                sy = 600.0
            else
                sx = 0.0
                sy = rand_float(0.0, 600.0)
            let ddx: Float = player_x - sx
            let ddy: Float = player_y - sy
            let dist: Float = sqrt(ddx * ddx + ddy * ddy)
            if dist > 1.0
                ddx = ddx / dist
                ddy = ddy / dist
            ex = ex + [sx]
            ey = ey + [sy]
            evx = evx + [ddx * spd]
            evy = evy + [ddy * spd]
            elife = elife + [1.0]
        wave = wave + 1
        enemies_per_wave = 3 + wave
        spawn_timer = 3.0 - float(wave) * 0.2
        if spawn_timer < 0.5
            spawn_timer = 0.5
    for i in range(0, len(ex))
        ex[i] = ex[i] + evx[i] * dt
        ey[i] = ey[i] + evy[i] * dt
        elife[i] = elife[i] - dt
        if elife[i] > 0.0
            let cdx: Float = player_x - ex[i]
            let cdy: Float = player_y - ey[i]
            let cdist: Float = sqrt(cdx * cdx + cdy * cdy)
            if cdist < 20.0
                game_over = true

fn draw()
    draw_circle(player_x, player_y, 12.0)
    for i in range(0, len(ex))
        if elife[i] > 0.0
            draw_rect(ex[i], ey[i], 16.0, 16.0)
    draw_text("Wave: " + str(wave), 10.0, 10.0)
    if game_over
        draw_text("GAME OVER", 340.0, 280.0)
