let player_x: Float = 400.0
let player_y: Float = 300.0
let player_speed: Float = 300.0
let spawn_timer: Float = 0.3
let survived_time: Float = 0.0
let is_hit: Bool = false
let bx: List[Float] = []
let by: List[Float] = []
let bvx: List[Float] = []
let bvy: List[Float] = []
let blife: List[Float] = []

fn update(dt: Float)
    if is_hit
        return
    if key_down("right")
        player_x = player_x + player_speed * dt
    if key_down("left")
        player_x = player_x - player_speed * dt
    if key_down("down")
        player_y = player_y + player_speed * dt
    if key_down("up")
        player_y = player_y - player_speed * dt
    survived_time = survived_time + dt
    spawn_timer = spawn_timer - dt
    if spawn_timer <= 0.0
        spawn_timer = 0.3
        let edge: Float = rand_float(0.0, 4.0)
        let sx: Float = 0.0
        let sy: Float = 0.0
        if edge < 1.0
            sx = rand_float(0.0, 800.0)
            sy = 0.0
        else if edge < 2.0
            sx = 800.0
            sy = rand_float(0.0, 600.0)
        else if edge < 3.0
            sx = rand_float(0.0, 800.0)
            sy = 600.0
        else
            sx = 0.0
            sy = rand_float(0.0, 600.0)
        let ddx: Float = player_x - sx
        let ddy: Float = player_y - sy
        let dist: Float = sqrt(ddx * ddx + ddy * ddy)
        if dist > 1.0
            ddx = ddx / dist
            ddy = ddy / dist
        bx = bx + [sx]
        by = by + [sy]
        bvx = bvx + [ddx * 250.0]
        bvy = bvy + [ddy * 250.0]
        blife = blife + [4.0]
    for i in range(0, len(bx))
        bx[i] = bx[i] + bvx[i] * dt
        by[i] = by[i] + bvy[i] * dt
        blife[i] = blife[i] - dt
        if blife[i] > 0.0
            let cdx: Float = player_x - bx[i]
            let cdy: Float = player_y - by[i]
            let cdist: Float = sqrt(cdx * cdx + cdy * cdy)
            if cdist < 13.0
                is_hit = true

fn draw()
    draw_circle(player_x, player_y, 10.0)
    for i in range(0, len(bx))
        if blife[i] > 0.0
            draw_rect(bx[i], by[i], 6.0, 6.0)
    if is_hit
        draw_text("HIT! Time: " + str(int(survived_time)), 320.0, 280.0)
    else
        draw_text("Time: " + str(int(survived_time)), 10.0, 10.0)
