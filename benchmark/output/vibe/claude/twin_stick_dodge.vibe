-- Twin-Stick Dodge: dodge bullets from all edges
let player_x: Float = 400.0
let player_y: Float = 300.0
let player_speed: Float = 300.0

let bx: List[Float] = []
let by: List[Float] = []
let bvx: List[Float] = []
let bvy: List[Float] = []
let blife: List[Float] = []

let spawn_timer: Float = 0.3
let survived_time: Float = 0.0
let hit: Bool = false

fn update(dt: Float)
    if hit
        return
    survived_time = survived_time + dt
    -- Move player
    if key_down("left")
        player_x = player_x - player_speed * dt
    if key_down("right")
        player_x = player_x + player_speed * dt
    if key_down("up")
        player_y = player_y - player_speed * dt
    if key_down("down")
        player_y = player_y + player_speed * dt
    -- Clamp player to screen
    if player_x < 10.0
        player_x = 10.0
    if player_x > 790.0
        player_x = 790.0
    if player_y < 10.0
        player_y = 10.0
    if player_y > 590.0
        player_y = 590.0
    -- Spawn bullets
    spawn_timer = spawn_timer - dt
    if spawn_timer <= 0.0
        spawn_timer = 0.3
        let edge: Float = rand_float(0.0, 4.0)
        let sx: Float = 0.0
        let sy: Float = 0.0
        if edge < 1.0
            sx = rand_float(0.0, 800.0)
            sy = -10.0
        else if edge < 2.0
            sx = 810.0
            sy = rand_float(0.0, 600.0)
        else if edge < 3.0
            sx = rand_float(0.0, 800.0)
            sy = 610.0
        else
            sx = -10.0
            sy = rand_float(0.0, 600.0)
        -- Aim toward player
        let dx: Float = player_x - sx
        let dy: Float = player_y - sy
        let dist: Float = sqrt(dx * dx + dy * dy)
        if dist > 1.0
            dx = dx / dist
            dy = dy / dist
        bx = bx + [sx]
        by = by + [sy]
        bvx = bvx + [dx * 250.0]
        bvy = bvy + [dy * 250.0]
        blife = blife + [4.0]
    -- Move bullets and check collision
    for i in range(0, len(bx))
        if blife[i] > 0.0
            bx[i] = bx[i] + bvx[i] * dt
            by[i] = by[i] + bvy[i] * dt
            blife[i] = blife[i] - dt
            let cdx: Float = player_x - bx[i]
            let cdy: Float = player_y - by[i]
            let cd: Float = sqrt(cdx * cdx + cdy * cdy)
            if cd < 13.0
                hit = true

fn draw()
    draw_circle(player_x, player_y, 10.0)
    for i in range(0, len(bx))
        if blife[i] > 0.0
            draw_rect(bx[i] - 3.0, by[i] - 3.0, 6.0, 6.0)
    draw_text("Time: " + str(int(survived_time)), 10.0, 10.0)
    if hit
        draw_text("HIT! Time: " + str(int(survived_time)), 300.0, 280.0)
