let cells: List[Float] = []
let next_cells: List[Float] = []
let sim_timer: Float = 0.0
let generation: Int = 0
let paused: Bool = false

fn load()
    for i in range(0, 300)
        if rand_float(0.0, 1.0) > 0.7
            cells = cells + [1.0]
        else
            cells = cells + [0.0]
        next_cells = next_cells + [0.0]

fn keypressed(k: String)
    if k == "space"
        if paused
            paused = false
        else
            paused = true

fn update(dt: Float)
    if not paused
        sim_timer = sim_timer + dt
        if sim_timer >= 0.2
            sim_timer = 0.0
            generation = generation + 1
            for row in range(0, 15)
                for col in range(0, 20)
                    let count: Int = 0
                    if row > 0 and col > 0
                        if cells[(row - 1) * 20 + col - 1] == 1.0
                            count = count + 1
                    if row > 0
                        if cells[(row - 1) * 20 + col] == 1.0
                            count = count + 1
                    if row > 0 and col < 19
                        if cells[(row - 1) * 20 + col + 1] == 1.0
                            count = count + 1
                    if col > 0
                        if cells[row * 20 + col - 1] == 1.0
                            count = count + 1
                    if col < 19
                        if cells[row * 20 + col + 1] == 1.0
                            count = count + 1
                    if row < 14 and col > 0
                        if cells[(row + 1) * 20 + col - 1] == 1.0
                            count = count + 1
                    if row < 14
                        if cells[(row + 1) * 20 + col] == 1.0
                            count = count + 1
                    if row < 14 and col < 19
                        if cells[(row + 1) * 20 + col + 1] == 1.0
                            count = count + 1
                    let idx: Int = row * 20 + col
                    if cells[idx] == 1.0
                        if count == 2 or count == 3
                            next_cells[idx] = 1.0
                        else
                            next_cells[idx] = 0.0
                    else
                        if count == 3
                            next_cells[idx] = 1.0
                        else
                            next_cells[idx] = 0.0
            for i in range(0, 300)
                cells[i] = next_cells[i]

fn draw()
    for row in range(0, 15)
        for col in range(0, 20)
            if cells[row * 20 + col] == 1.0
                draw_rect(float(col) * 40.0, float(row) * 40.0, 38.0, 38.0)
    draw_text("Gen: " + str(generation), 10.0, 10.0)
    if paused
        draw_text("PAUSED", 350.0, 10.0)
