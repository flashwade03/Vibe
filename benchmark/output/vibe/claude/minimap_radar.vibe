-- Minimap Radar: large 2000x2000 world with camera and corner minimap
let player_x: Float = 1000.0
let player_y: Float = 1000.0
let player_speed: Float = 300.0
let world_w: Float = 2000.0
let world_h: Float = 2000.0

let item_xs: List[Float] = []
let item_ys: List[Float] = []

fn load()
    for i in range(0, 20)
        item_xs = item_xs + [rand_float(0.0, 2000.0)]
        item_ys = item_ys + [rand_float(0.0, 2000.0)]

fn update(dt: Float)
    if key_down("left")
        player_x = player_x - player_speed * dt
    if key_down("right")
        player_x = player_x + player_speed * dt
    if key_down("up")
        player_y = player_y - player_speed * dt
    if key_down("down")
        player_y = player_y + player_speed * dt
    -- Clamp to world
    if player_x < 0.0
        player_x = 0.0
    if player_x > world_w
        player_x = world_w
    if player_y < 0.0
        player_y = 0.0
    if player_y > world_h
        player_y = world_h

fn draw()
    -- Draw items in camera space
    let cam_x: Float = player_x - 400.0
    let cam_y: Float = player_y - 300.0
    for i in range(0, len(item_xs))
        let draw_x: Float = item_xs[i] - cam_x
        let draw_y: Float = item_ys[i] - cam_y
        if draw_x > -20.0 and draw_x < 820.0 and draw_y > -20.0 and draw_y < 620.0
            draw_rect(draw_x, draw_y, 10.0, 10.0)
    -- Draw player at screen center
    draw_rect(392.0, 292.0, 16.0, 16.0)
    -- Minimap background
    draw_rect(630.0, 10.0, 160.0, 120.0)
    -- Minimap items
    for i in range(0, len(item_xs))
        let mx: Float = 630.0 + (item_xs[i] / world_w) * 160.0
        let my: Float = 10.0 + (item_ys[i] / world_h) * 120.0
        draw_rect(mx, my, 2.0, 2.0)
    -- Minimap player dot
    let mpx: Float = 630.0 + (player_x / world_w) * 160.0
    let mpy: Float = 10.0 + (player_y / world_h) * 120.0
    draw_circle(mpx, mpy, 3.0)
    -- Position text
    draw_text("Pos: " + str(int(player_x)) + ", " + str(int(player_y)), 10.0, 10.0)
