let last_key: String = "none"
let key_count: Int = 0

fn keypressed(k: String)
    last_key = k
    key_count = key_count + 1

fn draw()
    draw_text("Last Key: " + last_key, 250.0, 250.0)
    draw_text("Total Presses: " + str(key_count), 250.0, 290.0)
    draw_rect(300.0, 350.0, 200.0, 80.0)
    draw_text(last_key, 370.0, 380.0)
