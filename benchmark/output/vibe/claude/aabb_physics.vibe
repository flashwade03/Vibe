let box_xs: List[Float] = []
let box_ys: List[Float] = []
let box_vys: List[Float] = []
let box_ws: List[Float] = []
let box_hs: List[Float] = []
let plat_xs: List[Float] = [50.0, 300.0, 550.0]
let plat_ys: List[Float] = [450.0, 350.0, 450.0]
let plat_ws: List[Float] = [200.0, 200.0, 200.0]

fn load()
    for i in range(0, 6)
        box_xs = box_xs + [80.0 + float(i) * 110.0]
        box_ys = box_ys + [rand_float(50.0, 200.0)]
        box_vys = box_vys + [0.0]
        box_ws = box_ws + [rand_float(30.0, 60.0)]
        box_hs = box_hs + [rand_float(30.0, 60.0)]

fn keypressed(k: String)
    if k == "space"
        for i in range(0, 6)
            box_ys[i] = rand_float(50.0, 200.0)
            box_vys[i] = 0.0

fn update(dt: Float)
    for i in range(0, 6)
        box_vys[i] = box_vys[i] + 300.0 * dt
        box_ys[i] = box_ys[i] + box_vys[i] * dt
        if box_ys[i] + box_hs[i] > 580.0
            box_ys[i] = 580.0 - box_hs[i]
            box_vys[i] = 0.0
        for j in range(0, 3)
            if box_vys[i] >= 0.0 and box_xs[i] + box_ws[i] > plat_xs[j] and box_xs[i] < plat_xs[j] + plat_ws[j] and box_ys[i] + box_hs[i] >= plat_ys[j] and box_ys[i] + box_hs[i] <= plat_ys[j] + 20.0
                box_ys[i] = plat_ys[j] - box_hs[i]
                box_vys[i] = 0.0
    for i in range(0, 6)
        for j in range(0, 6)
            if j > i and box_xs[i] < box_xs[j] + box_ws[j] and box_xs[i] + box_ws[i] > box_xs[j] and box_ys[i] < box_ys[j] + box_hs[j] and box_ys[i] + box_hs[i] > box_ys[j]
                let ov: Float = (box_xs[i] + box_ws[i]) - box_xs[j]
                if ov > 0.0
                    box_xs[i] = box_xs[i] - ov * 0.5
                    box_xs[j] = box_xs[j] + ov * 0.5

fn draw()
    for i in range(0, 6)
        draw_rect(box_xs[i], box_ys[i], box_ws[i], box_hs[i])
    for j in range(0, 3)
        draw_rect(plat_xs[j], plat_ys[j], plat_ws[j], 15.0)
    draw_text("Space: Reset", 10.0, 10.0)
