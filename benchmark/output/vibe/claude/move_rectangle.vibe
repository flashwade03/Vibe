-- Move Rectangle: arrow keys move a 32x32 rectangle at 200 px/s
let x: Float = 400.0
let y: Float = 300.0
let speed: Float = 200.0

fn update(dt: Float)
    if key_down("right")
        x = x + speed * dt
    if key_down("left")
        x = x - speed * dt
    if key_down("down")
        y = y + speed * dt
    if key_down("up")
        y = y - speed * dt

fn draw()
    draw_rect(x, y, 32.0, 32.0)
