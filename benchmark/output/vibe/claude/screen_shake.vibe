let shake_x: Float = 0.0
let shake_y: Float = 0.0
let shake_timer: Float = 0.0
let shake_intensity: Float = 0.0

fn keypressed(k: String)
    if k == "space"
        shake_timer = 0.5
        shake_intensity = 15.0

fn update(dt: Float)
    if shake_timer > 0.0
        shake_timer = shake_timer - dt
        shake_x = rand_float(0.0 - shake_intensity, shake_intensity)
        shake_y = rand_float(0.0 - shake_intensity, shake_intensity)
        shake_intensity = shake_intensity - 20.0 * dt
    if shake_timer <= 0.0
        shake_x = 0.0
        shake_y = 0.0

fn draw()
    draw_rect(368.0 + shake_x, 268.0 + shake_y, 64.0, 64.0)
    draw_rect(50.0 + shake_x, 50.0 + shake_y, 16.0, 16.0)
    draw_rect(734.0 + shake_x, 50.0 + shake_y, 16.0, 16.0)
    draw_rect(50.0 + shake_x, 534.0 + shake_y, 16.0, 16.0)
    draw_rect(734.0 + shake_x, 534.0 + shake_y, 16.0, 16.0)
    draw_text("Press SPACE to shake", 280.0 + shake_x, 550.0 + shake_y)
