let path_xs: List[Float] = [0.0, 200.0, 200.0, 600.0, 600.0, 800.0]
let path_ys: List[Float] = [300.0, 300.0, 100.0, 100.0, 500.0, 500.0]
let en_xs: List[Float] = []
let en_ys: List[Float] = []
let en_wp: List[Float] = []
let en_hp: List[Float] = []
let spawn_timer: Float = 2.0
let enemy_speed: Float = 80.0
let score: Int = 0
let lives: Int = 10
let tow_xs: List[Float] = []
let tow_ys: List[Float] = []
let tow_timers: List[Float] = []
let proj_xs: List[Float] = []
let proj_ys: List[Float] = []
let proj_txs: List[Float] = []
let proj_tys: List[Float] = []
let proj_alive: List[Float] = []

fn mousepressed(mx: Float, my: Float, button: Int)
    if len(tow_xs) < 5
        tow_xs = tow_xs + [mx]
        tow_ys = tow_ys + [my]
        tow_timers = tow_timers + [0.0]

fn update(dt: Float)
    spawn_timer = spawn_timer - dt
    if spawn_timer <= 0.0
        spawn_timer = 2.0
        en_xs = en_xs + [0.0]
        en_ys = en_ys + [300.0]
        en_wp = en_wp + [1.0]
        en_hp = en_hp + [3.0]
    for i in range(0, len(en_xs))
        if en_hp[i] > 0.0
            let wi: Int = int(en_wp[i])
            if wi < 6
                let dx: Float = path_xs[wi] - en_xs[i]
                let dy: Float = path_ys[wi] - en_ys[i]
                let d: Float = sqrt(dx * dx + dy * dy)
                if d > 3.0
                    en_xs[i] = en_xs[i] + (dx / d) * enemy_speed * dt
                    en_ys[i] = en_ys[i] + (dy / d) * enemy_speed * dt
                else
                    en_wp[i] = en_wp[i] + 1.0
            if int(en_wp[i]) >= 6
                en_hp[i] = 0.0
                lives = lives - 1
    for t in range(0, len(tow_xs))
        tow_timers[t] = tow_timers[t] - dt
        if tow_timers[t] <= 0.0
            let best: Int = -1
            let best_d: Float = 151.0
            for i in range(0, len(en_xs))
                if en_hp[i] > 0.0
                    let td: Float = sqrt((tow_xs[t] - en_xs[i]) * (tow_xs[t] - en_xs[i]) + (tow_ys[t] - en_ys[i]) * (tow_ys[t] - en_ys[i]))
                    if td < best_d
                        best_d = td
                        best = i
            if best >= 0
                tow_timers[t] = 1.0
                proj_xs = proj_xs + [tow_xs[t]]
                proj_ys = proj_ys + [tow_ys[t]]
                proj_txs = proj_txs + [en_xs[best]]
                proj_tys = proj_tys + [en_ys[best]]
                proj_alive = proj_alive + [1.0]
    for p in range(0, len(proj_xs))
        if proj_alive[p] == 1.0
            let pdx: Float = proj_txs[p] - proj_xs[p]
            let pdy: Float = proj_tys[p] - proj_ys[p]
            let pd: Float = sqrt(pdx * pdx + pdy * pdy)
            if pd > 10.0
                proj_xs[p] = proj_xs[p] + (pdx / pd) * 300.0 * dt
                proj_ys[p] = proj_ys[p] + (pdy / pd) * 300.0 * dt
            else
                proj_alive[p] = 0.0
                for i in range(0, len(en_xs))
                    if en_hp[i] > 0.0
                        let ed: Float = sqrt((proj_xs[p] - en_xs[i]) * (proj_xs[p] - en_xs[i]) + (proj_ys[p] - en_ys[i]) * (proj_ys[p] - en_ys[i]))
                        if ed < 10.0
                            en_hp[i] = en_hp[i] - 1.0
                            if en_hp[i] <= 0.0
                                score = score + 1

fn draw()
    for i in range(0, 5)
        for j in range(0, 20)
            let lt: Float = float(j) / 20.0
            let lx: Float = path_xs[i] + (path_xs[i + 1] - path_xs[i]) * lt
            let ly: Float = path_ys[i] + (path_ys[i + 1] - path_ys[i]) * lt
            draw_circle(lx, ly, 2.0)
    for i in range(0, len(en_xs))
        if en_hp[i] > 0.0
            draw_circle(en_xs[i], en_ys[i], 8.0)
    for t in range(0, len(tow_xs))
        draw_rect(tow_xs[t] - 10.0, tow_ys[t] - 10.0, 20.0, 20.0)
    for p in range(0, len(proj_xs))
        if proj_alive[p] == 1.0
            draw_rect(proj_xs[p], proj_ys[p], 4.0, 4.0)
    draw_text("Lives: " + str(lives) + " Score: " + str(score), 10.0, 10.0)
    draw_text("Click to place tower (" + str(len(tow_xs)) + "/5)", 10.0, 30.0)
