let player_x: Float = 100.0
let player_y: Float = 400.0
let vy: Float = 0.0
let on_ground: Bool = false
let prev_y: Float = 400.0
let speed: Float = 250.0
let gravity: Float = 600.0
let plat_xs: List[Float] = [50.0, 300.0, 500.0, 200.0, 450.0]
let plat_ys: List[Float] = [450.0, 380.0, 300.0, 220.0, 150.0]
let plat_ws: List[Float] = [200.0, 150.0, 180.0, 120.0, 200.0]

fn update(dt: Float)
    if key_down("left")
        player_x = player_x - speed * dt
    if key_down("right")
        player_x = player_x + speed * dt
    if key_down("up") and on_ground
        vy = -350.0
        on_ground = false
    prev_y = player_y
    vy = vy + gravity * dt
    player_y = player_y + vy * dt
    on_ground = false
    for i in range(0, 5)
        if vy >= 0.0 and prev_y + 20.0 <= plat_ys[i] and player_y + 20.0 >= plat_ys[i] and player_x + 20.0 > plat_xs[i] and player_x < plat_xs[i] + plat_ws[i]
            player_y = plat_ys[i] - 20.0
            vy = 0.0
            on_ground = true
    if vy >= 0.0 and player_y + 20.0 >= 580.0
        player_y = 560.0
        vy = 0.0
        on_ground = true
    if player_y > 620.0
        player_x = 100.0
        player_y = 400.0
        vy = 0.0

fn draw()
    draw_rect(player_x, player_y, 20.0, 20.0)
    for i in range(0, 5)
        draw_rect(plat_xs[i], plat_ys[i], plat_ws[i], 12.0)
    draw_text("Use arrows + up to jump", 10.0, 10.0)
