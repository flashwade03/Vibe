-- Platformer Level: player with gravity, 5 platforms, jump mechanic
let px: Float = 100.0
let py: Float = 400.0
let prev_py: Float = 400.0
let vy: Float = 0.0
let speed: Float = 250.0
let gravity: Float = 600.0
let on_ground: Bool = false

let plat_xs: List[Float] = [50.0, 300.0, 500.0, 200.0, 450.0]
let plat_ys: List[Float] = [450.0, 380.0, 300.0, 220.0, 150.0]
let plat_ws: List[Float] = [200.0, 150.0, 180.0, 120.0, 200.0]
let plat_h: Float = 12.0
let pw: Float = 20.0
let ph: Float = 20.0

fn keypressed(k: String)
    if k == "up"
        if on_ground
            vy = -350.0
            on_ground = false

fn update(dt: Float)
    -- Horizontal movement
    if key_down("left")
        px = px - speed * dt
    if key_down("right")
        px = px + speed * dt
    if px < 0.0
        px = 0.0
    if px > 800.0 - pw
        px = 800.0 - pw
    -- Save previous y
    prev_py = py
    -- Apply gravity
    vy = vy + gravity * dt
    py = py + vy * dt
    -- Platform collision
    on_ground = false
    for i in range(0, len(plat_xs))
        if vy >= 0.0
            if prev_py + ph <= plat_ys[i]
                if py + ph >= plat_ys[i]
                    if px + pw > plat_xs[i]
                        if px < plat_xs[i] + plat_ws[i]
                            py = plat_ys[i] - ph
                            vy = 0.0
                            on_ground = true
    -- Ground at y=580
    if vy >= 0.0
        if py + ph >= 580.0
            py = 580.0 - ph
            vy = 0.0
            on_ground = true
    -- Reset if fallen off
    if py > 620.0
        px = 100.0
        py = 400.0
        vy = 0.0

fn draw()
    -- Draw platforms
    for i in range(0, len(plat_xs))
        draw_rect(plat_xs[i], plat_ys[i], plat_ws[i], plat_h)
    -- Draw ground
    draw_rect(0.0, 580.0, 800.0, 20.0)
    -- Draw player
    draw_rect(px, py, pw, ph)
    draw_text("Use arrows + up to jump", 10.0, 10.0)
