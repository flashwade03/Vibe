-- Enemy Follow: enemy rectangle follows the player
let player_x: Float = 400.0
let player_y: Float = 300.0
let player_speed: Float = 200.0
let enemy_x: Float = 100.0
let enemy_y: Float = 100.0
let enemy_speed: Float = 100.0

fn update(dt: Float)
    -- Move player with arrow keys
    if key_down("right")
        player_x = player_x + player_speed * dt
    if key_down("left")
        player_x = player_x - player_speed * dt
    if key_down("down")
        player_y = player_y + player_speed * dt
    if key_down("up")
        player_y = player_y - player_speed * dt
    -- Enemy follows player
    let dx: Float = player_x - enemy_x
    let dy: Float = player_y - enemy_y
    let dist: Float = sqrt(dx * dx + dy * dy)
    if dist > 1.0
        enemy_x = enemy_x + (dx / dist) * enemy_speed * dt
        enemy_y = enemy_y + (dy / dist) * enemy_speed * dt

fn draw()
    draw_rect(player_x, player_y, 32.0, 32.0)
    draw_rect(enemy_x, enemy_y, 32.0, 32.0)
    draw_text("Player", player_x, player_y - 15.0)
    draw_text("Enemy", enemy_x, enemy_y - 15.0)
