-- State Machine Game: rectangle with idle, moving, jumping states
-- state: 0=idle, 1=moving, 2=jumping
let x: Float = 384.0
let y: Float = 500.0
let vy: Float = 0.0
let speed: Float = 200.0
let gravity: Float = 600.0
let ground_y: Float = 500.0
let state: Int = 0

fn keypressed(k: String)
    if k == "space"
        if state != 2
            vy = -350.0
            state = 2

fn update(dt: Float)
    let moving: Bool = false
    -- Horizontal movement
    if key_down("left")
        x = x - speed * dt
        moving = true
    if key_down("right")
        x = x + speed * dt
        moving = true
    -- Apply gravity
    vy = vy + gravity * dt
    y = y + vy * dt
    -- Ground collision
    if y >= ground_y
        y = ground_y
        vy = 0.0
        if state == 2
            state = 0
    -- Update state
    if state != 2
        if moving
            state = 1
        else
            state = 0

fn draw()
    draw_rect(x, y, 32.0, 32.0)
    -- Draw ground
    draw_rect(0.0, 532.0, 800.0, 68.0)
    -- Display current state
    if state == 0
        draw_text("State: IDLE", 10.0, 10.0)
    else if state == 1
        draw_text("State: MOVING", 10.0, 10.0)
    else
        draw_text("State: JUMPING", 10.0, 10.0)
    draw_text("Arrows to move, SPACE to jump", 10.0, 40.0)
