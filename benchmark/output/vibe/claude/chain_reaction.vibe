-- Chain Reaction: click to start a chain reaction of expanding circles
let cx: List[Float] = []
let cy: List[Float] = []
let cr: List[Float] = []
let cstate: List[Float] = []
let ctimer: List[Float] = []

fn load()
    -- Place 25 circles randomly
    for i in range(0, 25)
        cx = cx + [rand_float(60.0, 740.0)]
        cy = cy + [rand_float(60.0, 540.0)]
        cr = cr + [12.0]
        cstate = cstate + [0.0]
        ctimer = ctimer + [0.0]

fn mousepressed(mx: Float, my: Float, button: Int)
    -- Find and trigger the closest idle circle near the click
    for i in range(0, len(cx))
        if cstate[i] == 0.0
            let dx: Float = mx - cx[i]
            let dy: Float = my - cy[i]
            let dist: Float = sqrt(dx * dx + dy * dy)
            if dist < 20.0
                cstate[i] = 1.0

fn update(dt: Float)
    for i in range(0, len(cx))
        if cstate[i] == 1.0
            -- Expanding phase
            cr[i] = cr[i] + 60.0 * dt
            ctimer[i] = ctimer[i] + dt
            if ctimer[i] > 1.2
                cstate[i] = 2.0
            -- Trigger nearby idle circles
            for j in range(0, len(cx))
                if cstate[j] == 0.0
                    let dx: Float = cx[i] - cx[j]
                    let dy: Float = cy[i] - cy[j]
                    let dist: Float = sqrt(dx * dx + dy * dy)
                    if dist < cr[i] + 12.0
                        cstate[j] = 1.0

fn draw()
    for i in range(0, len(cx))
        if cstate[i] == 0.0
            draw_circle(cx[i], cy[i], 12.0)
        else if cstate[i] == 1.0
            draw_circle(cx[i], cy[i], cr[i])
        else
            draw_circle(cx[i], cy[i], 4.0)
    -- Count triggered
    let triggered: Int = 0
    for i in range(0, len(cx))
        if cstate[i] > 0.0
            triggered = triggered + 1
    draw_text("Triggered: " + str(triggered) + " / " + str(len(cx)), 10.0, 10.0)
    draw_text("Click a circle to start!", 10.0, 35.0)
