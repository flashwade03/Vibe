let cx: List[Float] = []
let cy: List[Float] = []
let cstate: List[Float] = []
let cradius: List[Float] = []
let ctimer: List[Float] = []

fn load()
    for i in range(0, 30)
        cx = cx + [rand_float(50.0, 750.0)]
        cy = cy + [rand_float(50.0, 550.0)]
        cstate = cstate + [0.0]
        cradius = cradius + [15.0]
        ctimer = ctimer + [0.0]

fn mousepressed(mx: Float, my: Float, button: Int)
    for i in range(0, 30)
        if cstate[i] == 0.0
            let ddx: Float = mx - cx[i]
            let ddy: Float = my - cy[i]
            let dist: Float = sqrt(ddx * ddx + ddy * ddy)
            if dist < 15.0
                cstate[i] = 1.0

fn update(dt: Float)
    for i in range(0, 30)
        if cstate[i] == 1.0
            cradius[i] = cradius[i] + 80.0 * dt
            ctimer[i] = ctimer[i] + dt
            if ctimer[i] > 1.0
                cstate[i] = 2.0
            for j in range(0, 30)
                if cstate[j] == 0.0
                    let ddx: Float = cx[i] - cx[j]
                    let ddy: Float = cy[i] - cy[j]
                    let dist: Float = sqrt(ddx * ddx + ddy * ddy)
                    if dist < cradius[i] + 15.0
                        cstate[j] = 1.0

fn draw()
    let exploded: Int = 0
    for i in range(0, 30)
        if cstate[i] == 0.0
            draw_circle(cx[i], cy[i], 15.0)
        else if cstate[i] == 1.0
            draw_circle(cx[i], cy[i], cradius[i])
        else
            draw_circle(cx[i], cy[i], 3.0)
        if cstate[i] > 0.0
            exploded = exploded + 1
    draw_text("Exploded: " + str(exploded), 10.0, 10.0)
