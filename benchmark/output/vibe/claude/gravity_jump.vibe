-- Gravity Jump: rectangle with gravity, press space to jump
let x: Float = 384.0
let y: Float = 500.0
let vy: Float = 0.0
let speed: Float = 200.0
let gravity: Float = 600.0
let jump_force: Float = -400.0
let ground_y: Float = 550.0
let on_ground: Bool = true

fn keypressed(k: String)
    if k == "space"
        if on_ground
            vy = jump_force
            on_ground = false

fn update(dt: Float)
    -- Horizontal movement
    if key_down("left")
        x = x - speed * dt
    if key_down("right")
        x = x + speed * dt
    -- Apply gravity
    vy = vy + gravity * dt
    y = y + vy * dt
    -- Ground collision
    if y >= ground_y
        y = ground_y
        vy = 0.0
        on_ground = true

fn draw()
    draw_rect(x, y, 32.0, 32.0)
    -- Draw ground line
    draw_rect(0.0, 582.0, 800.0, 18.0)
    draw_text("Press SPACE to jump", 10.0, 10.0)
