-- Shooting: player shoots bullets upward with spacebar
let player_x: Float = 384.0
let player_y: Float = 550.0
let speed: Float = 200.0
let bullet_xs: List[Float] = []
let bullet_ys: List[Float] = []
let bullet_speed: Float = 300.0

fn keypressed(k: String)
    if k == "space"
        bullet_xs = bullet_xs + [player_x + 14.0]
        bullet_ys = bullet_ys + [player_y]

fn update(dt: Float)
    if key_down("left")
        player_x = player_x - speed * dt
    if key_down("right")
        player_x = player_x + speed * dt
    for i in range(0, len(bullet_ys))
        bullet_ys[i] = bullet_ys[i] - bullet_speed * dt

fn draw()
    draw_rect(player_x, player_y, 32.0, 32.0)
    for i in range(0, len(bullet_xs))
        draw_rect(bullet_xs[i], bullet_ys[i], 4.0, 4.0)
