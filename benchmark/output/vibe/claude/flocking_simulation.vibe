-- Flocking Simulation: 15 simplified boids with cohesion and separation
let boid_xs: List[Float] = []
let boid_ys: List[Float] = []
let boid_vxs: List[Float] = []
let boid_vys: List[Float] = []

fn load()
    for i in range(0, 15)
        boid_xs = boid_xs + [rand_float(0.0, 800.0)]
        boid_ys = boid_ys + [rand_float(0.0, 600.0)]
        boid_vxs = boid_vxs + [rand_float(-50.0, 50.0)]
        boid_vys = boid_vys + [rand_float(-50.0, 50.0)]

fn update(dt: Float)
    -- Compute center of mass
    let cx: Float = 0.0
    let cy: Float = 0.0
    for i in range(0, 15)
        cx = cx + boid_xs[i]
        cy = cy + boid_ys[i]
    cx = cx / 15.0
    cy = cy / 15.0
    -- Update each boid
    for i in range(0, 15)
        -- Cohesion: steer toward center
        boid_vxs[i] = boid_vxs[i] + (cx - boid_xs[i]) * 0.5 * dt
        boid_vys[i] = boid_vys[i] + (cy - boid_ys[i]) * 0.5 * dt
        -- Separation: push away from nearby boids
        for j in range(0, 15)
            if i != j
                let dx: Float = boid_xs[i] - boid_xs[j]
                let dy: Float = boid_ys[i] - boid_ys[j]
                let dist: Float = sqrt(dx * dx + dy * dy)
                if dist < 30.0 and dist > 0.1
                    boid_vxs[i] = boid_vxs[i] + (dx / dist) * 100.0 * dt
                    boid_vys[i] = boid_vys[i] + (dy / dist) * 100.0 * dt
        -- Clamp speed
        let spd: Float = sqrt(boid_vxs[i] * boid_vxs[i] + boid_vys[i] * boid_vys[i])
        if spd > 150.0
            boid_vxs[i] = boid_vxs[i] / spd * 150.0
            boid_vys[i] = boid_vys[i] / spd * 150.0
        -- Move
        boid_xs[i] = boid_xs[i] + boid_vxs[i] * dt
        boid_ys[i] = boid_ys[i] + boid_vys[i] * dt
        -- Wrap edges
        if boid_xs[i] > 800.0
            boid_xs[i] = 0.0
        if boid_xs[i] < 0.0
            boid_xs[i] = 800.0
        if boid_ys[i] > 600.0
            boid_ys[i] = 0.0
        if boid_ys[i] < 0.0
            boid_ys[i] = 600.0

fn draw()
    for i in range(0, 15)
        draw_rect(boid_xs[i], boid_ys[i], 4.0, 4.0)
    draw_text("Boids: 15", 10.0, 10.0)
