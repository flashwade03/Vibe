-- Snake Movement: list of body segments following a head
let snake_xs: List[Float] = [400.0, 380.0, 360.0, 340.0, 320.0]
let snake_ys: List[Float] = [300.0, 300.0, 300.0, 300.0, 300.0]
let dir_x: Float = 1.0
let dir_y: Float = 0.0
let move_timer: Float = 0.0
let step_time: Float = 0.12
let cell_size: Float = 20.0

fn keypressed(k: String)
    if k == "right"
        if dir_x != -1.0
            dir_x = 1.0
            dir_y = 0.0
    else if k == "left"
        if dir_x != 1.0
            dir_x = -1.0
            dir_y = 0.0
    else if k == "up"
        if dir_y != 1.0
            dir_x = 0.0
            dir_y = -1.0
    else if k == "down"
        if dir_y != -1.0
            dir_x = 0.0
            dir_y = 1.0

fn update(dt: Float)
    move_timer = move_timer + dt
    if move_timer >= step_time
        move_timer = move_timer - step_time
        -- Compute new head position
        let new_x: Float = snake_xs[0] + dir_x * cell_size
        let new_y: Float = snake_ys[0] + dir_y * cell_size
        -- Wrap around screen
        if new_x >= 800.0
            new_x = 0.0
        if new_x < 0.0
            new_x = 780.0
        if new_y >= 600.0
            new_y = 0.0
        if new_y < 0.0
            new_y = 580.0
        -- Shift body segments backward
        let i: Int = len(snake_xs) - 1
        for i > 0
            snake_xs[i] = snake_xs[i - 1]
            snake_ys[i] = snake_ys[i - 1]
            i = i - 1
        -- Set new head
        snake_xs[0] = new_x
        snake_ys[0] = new_y

fn draw()
    for i in range(0, len(snake_xs))
        draw_rect(snake_xs[i], snake_ys[i], 18.0, 18.0)
    draw_text("Arrow keys to steer", 10.0, 10.0)
