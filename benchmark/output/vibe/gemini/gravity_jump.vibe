let x: Float = 384.0
let y: Float = 550.0
let vy: Float = 0.0
let on_ground: Bool = true

const SPEED: Float = 200.0
const GRAVITY: Float = 500.0
const JUMP_SPEED: Float = -300.0

fn update(dt: Float)
    if key_down("left")
        x = x - SPEED * dt
    if key_down("right")
        x = x + SPEED * dt

    if key_down("up") and on_ground
        vy = JUMP_SPEED
        on_ground = false

    vy = vy + GRAVITY * dt
    y = y + vy * dt

    if y >= 550.0
        y = 550.0
        vy = 0.0
        on_ground = true

fn draw()
    draw_rect(x, y, 32.0, 32.0)
