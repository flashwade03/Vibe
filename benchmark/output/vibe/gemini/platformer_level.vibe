let px: Float = 100.0
let py: Float = 400.0
let vx: Float = 0.0
let vy: Float = 0.0
let on_ground: Bool = false

let plat_xs: List[Float] = [50.0, 300.0, 500.0, 200.0, 450.0]
let plat_ys: List[Float] = [450.0, 380.0, 300.0, 220.0, 150.0]
let plat_ws: List[Float] = [200.0, 150.0, 180.0, 120.0, 200.0]

fn update(dt: Float)
    let prev_y: Float = py

    vx = 0.0
    if key_down("left")
        vx = -250.0
    if key_down("right")
        vx = 250.0

    px = px + vx * dt

    vy = vy + 600.0 * dt
    py = py + vy * dt

    on_ground = false

    for i in range(0, 5)
        if vy >= 0.0 and prev_y + 20.0 <= plat_ys[i]
            if py + 20.0 >= plat_ys[i] and px + 20.0 > plat_xs[i] and px < plat_xs[i] + plat_ws[i]
                py = plat_ys[i] - 20.0
                vy = 0.0
                on_ground = true

    if py + 20.0 >= 580.
