let ring_xs: List[Float] = []
let ring_ys: List[Float] = []
let ring_radii: List[Float] = []
let ring_lifes: List[Float] = []

fn mousepressed(mx: Float, my: Float, button: Int)
    ring_xs = ring_xs + [mx]
    ring_ys = ring_ys + [my]
    ring_radii = ring_radii + [5.0]
    ring_lifes = ring_lifes + [2.0]

fn update(dt: Float)
    for i in range(0, len(ring_xs))
        ring_radii[i] = ring_radii[i] + 80.0 * dt
        ring_lifes[i] = ring_lifes[i] - dt

fn draw()
    for i in range(0, len(ring_xs))
        if ring_lifes[i] > 0.0
            draw_circle(ring_xs[i], ring_ys[i], ring_radii[i])

    draw_text("Rings: " + str(len(ring_xs)), 10.0, 10.0)
    draw_text("Click to create rings", 280.0, 560.0)
