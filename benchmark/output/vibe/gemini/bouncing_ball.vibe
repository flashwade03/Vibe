let bx: Float = 400.0
let by: Float = 300.0
let vx: Float = 150.0
let vy: Float = 150.0
let radius: Float = 16.0

fn update(dt: Float)
    bx = bx + vx * dt
    by = by + vy * dt

    if bx < radius or bx > 800.0 - radius
        vx = -vx

    if by < radius or by > 600.0 - radius
        vy = -vy

fn draw()
    draw_circle(bx, by, radius)
