let bx: Float = 400.0
let by: Float = 300.0
let vx: Float = 150.0
let vy: Float = 150.0

fn update(dt: Float)
    bx += vx * dt
    by += vy * dt

    if bx - 16.0 < 0.0 or bx + 16.0 > 800.0
        vx = -vx

    if by - 16.0 < 0.0 or by + 16.0 > 600.0
        vy = -vy

fn draw()
    draw_circle(bx, by, 16.0)
