let player_x: Float = 400.0
let player_y: Float = 300.0
let player_speed: Float = 200.0

let enemy_x: Float = 100.0
let enemy_y: Float = 100.0
let enemy_speed: Float = 100.0

fn update(dt: Float)
    if key_down("right")
        player_x = player_x + player_speed * dt
    if key_down("left")
        player_x = player_x - player_speed * dt
    if key_down("down")
        player_y = player_y + player_speed * dt
    if key_down("up")
        player_y = player_y - player_speed * dt

    let dx: Float = player_x - enemy_x
    let dy: Float = player_y - enemy_y
    let dist: Float = sqrt(dx * dx + dy * dy)

    if dist > 1.0
        let nx: Float = dx / dist
        let ny: Float = dy / dist
        enemy_x = enemy_x + nx * enemy_speed * dt
        enemy_y = enemy_y + ny * enemy_speed * dt

fn draw()
    draw_rect(enemy_x, enemy_y, 32.0, 32.0, 0.0, 0.0)
    draw_rect(player_x, player_y, 32.0, 32.0, 0.0, 0.0)
