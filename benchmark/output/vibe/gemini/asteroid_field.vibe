let player_x: Float = 100.0
let player_y: Float = 300.0
let ast_xs: List[Float] = []
let ast_ys: List[Float] = []
let ast_sizes: List[Float] = []
let spawn_timer: Float = 0.0
let scroll_speed: Float = 200.0
let game_over: Bool = false
let score: Float = 0.0

fn update(dt: Float)
    if not game_over
        if key_down("up")
            player_y -= 250.0 * dt
        if key_down("down")
            player_y += 250.0 * dt

        if player_y < 0.0
            player_y = 0.0
        if player_y > 576.0
            player_y = 576.0

        spawn_timer += dt
        if spawn_timer >= 0.4
            spawn_timer = 0.0
            ast_xs = ast_xs + [820.0]
            ast_ys = ast_ys + [rand_float(20.0, 580.0)]
            ast_sizes = ast_sizes + [rand_float(15.0, 40.0)]

        for i in range(0, len(ast_xs))
            ast_xs[i] -= scroll_speed * dt
            if ast_xs[i] < player_x + 24.0 and ast_xs[i] + ast_sizes[i] > player_x and ast_ys[i] < player_y + 24.0 and ast_ys[i] + ast_sizes[i] > player_y
                game_over = true

        score += dt

fn draw()
    draw_rect(player_x, player_y, 24.0, 24.0)
    for i in range(0, len(ast_xs))
        draw_rect(ast_xs[i], ast_ys[i], ast_sizes[i], ast_sizes[i])

    draw_text("Score: " + str(int(score)), 10.0, 10.0)

    if game_over
        draw_text("GAME OVER", 340.0, 280.0)
