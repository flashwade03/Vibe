let snake_xs: List[Float] = [400.0, 380.0, 360.0]
let snake_ys: List[Float] = [300.0, 300.0, 300.0]
let dir_x: Float = 1.0
let dir_y: Float = 0.0
let move_timer: Float = 0.15

fn update(dt: Float)
    move_timer -= dt
    if move_timer <= 0.0
        move_timer = 0.15
        let new_x = snake_xs[0] + dir_x * 20.0
        let new_y = snake_ys[0] + dir_y * 20.0

        if new_x >= 800.0
            new_x = 0.0
        else if new_x < 0.0
            new_x = 780.0

        if new_y >= 600.0
            new_y = 0.0
        else if new_y < 0.0
            new_y = 580.0

        let i = len(snake_xs) - 1
        for i > 0
            snake_xs[i] = snake_xs[i-1]
            snake_ys[i] = snake_ys[i-1]
            i -= 1

        snake_xs[0] = new_x
        snake_ys[0] = new_y

fn keypressed(k: String)
    if k == "right" and dir_x != -1.0
        dir_x = 1.0
        dir_y = 0.0
    else if k == "left" and dir_x != 1.0
        dir_x = -1.0
        dir_y = 0.0
    else if k == "up" and dir_y != 1.0
        dir_x = 0.0
        dir_y = -1.0
    else if k == "down" and dir_y != -1.0
        dir_x = 0.0
        dir_y = 1.0

fn draw()
    for i in range(0, len(snake_xs))
        draw_rect(snake_xs[i] + 1.0, snake_ys[i] + 1.0, 18.0, 18.0)
