let px: Float = 384.0
let py: Float = 550.0
let p_speed: Float = 200.0
let bullet_xs: List[Float] = []
let bullet_ys: List[Float] = []
let b_speed: Float = 300.0

fn update(dt: Float)
    if key_down("left") and px > 0.0
        px -= p_speed * dt
    if key_down("right") and px < 768.0
        px += p_speed * dt

    for i in range(0, len(bullet_xs))
        bullet_ys[i] -= b_speed * dt

fn keypressed(k: String)
    if k == "space"
        bullet_xs += [px + 14.0]
        bullet_ys += [py]

fn draw()
    draw_rect(px, py, 32.0, 32.0)
    for i in range(0, len(bullet_xs))
        draw_rect(bullet_xs[i], bullet_ys[i], 4.0, 4.0)
