let boid_xs: List[Float] = []
let boid_ys: List[Float] = []
let boid_vxs: List[Float] = []
let boid_vys: List[Float] = []

fn load()
    for i in range(0, 15)
        boid_xs = boid_xs + [rand_float(0.0, 800.0)]
        boid_ys = boid_ys + [rand_float(0.0, 600.0)]
        boid_vxs = boid_vxs + [rand_float(-50.0, 50.0)]
        boid_vys = boid_vys + [rand_float(-50.0, 50.0)]

fn update(dt: Float)
    let sum_x: Float = 0.0
    let sum_y: Float = 0.0
    for i in range(0, 15)
        sum_x += boid_xs[i]
        sum_y += boid_ys[i]

    let center_x: Float = sum_x / 15.0
    let center_y: Float = sum_y / 15.0

    for i in range(0, 15)
        -- Cohesion
        boid_vxs[i] += (center_x - boid_xs[i]) * 0.5 * dt
        boid_vys[i] += (center_y - boid_ys[i]) * 0.5 * dt

        -- Separation
        for j in range(0, 15)
            if i != j
                let dx: Float = boid_xs[i] - boid_xs[j]
                let dy: Float = boid_ys[i] - boid_ys[j]
                let dist: Float = sqrt(dx * dx + dy * dy)
                if dist < 30.0 and dist > 0.0
                    boid_vxs[i] += (dx / dist) * 100.0 * dt
                    boid_vys[i] += (dy / dist) * 100.0 * dt

        -- Clamp speed
        let speed: Float = sqrt(boid_vxs[i] * boid_vxs[i] + boid_vys[i] * boid_vys[i])
        if speed > 150.0
            boid_vxs[i] = (boid_vxs[i] / speed) * 150.0
            boid_vys[i] = (boid_vys[i] / speed) * 150.0

        -- Update position
        boid_xs[i] += boid_vxs[i] * dt
        boid_ys[i] += boid_vys[i] * dt

        -- Wrap around
        if boid_xs[i] < 0.0
            boid_xs[i] = 800.0
        if boid_xs[i] > 800.0
            boid_xs[i] = 0.0
        if boid_ys[i] < 0.0
            boid_ys[i] = 600.0
        if boid_ys[i] > 600.0
            boid_ys[i] = 0.0

fn draw()
    for i in range(0, 15)
        draw_rect(boid_xs[i], boid_ys[i], 4.0, 4.0)
