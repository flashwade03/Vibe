let cx: List[Float] = []
let cy: List[Float] = []
let cstate: List[Float] = []
let cradius: List[Float] = []
let ctimer: List[Float] = []
let loaded: Bool = false

fn load()
    for i in range(0, 30)
        cx = cx + [rand_float(50.0, 750.0)]
        cy = cy + [rand_float(50.0, 550.0)]
        cstate = cstate + [0.0]
        cradius = cradius + [15.0]
        ctimer = ctimer + [0.0]

fn mousepressed(mx: Float, my: Float, button: Int)
    let min_dist: Float = 10000.0
    let closest: Int = -1
    for i in range(0, len(cx))
        let dx: Float = cx[i] - mx
        let dy: Float = cy[i] - my
        let dist: Float = sqrt(dx * dx + dy * dy)
        if dist < 15.0
            if dist < min_dist
                min_dist = dist
                closest = i

    if closest != -1
        cstate[closest] = 1.0

fn update(dt: Float)
    if not loaded
        load()
        loaded = true

    for i in range(0, len(cx))
        if cstate[i] == 1.0
            cradius[i] = cradius[i] + 80.0 * dt
            ctimer[i] = ctimer[i] + dt
            if ctimer[i] > 1.0
                cstate[i] = 2.0

            for j in range(0, len(cx))
                if cstate[j] == 0.0
                    let dx: Float = cx[j] - cx[i]
                    let dy: Float = cy[j] - cy[i]
                    let dist: Float = sqrt(dx * dx + dy * dy)
                    if dist < cradius[i] + 15.0
                        cstate[j] = 1.0

fn draw()
    let count: Int = 0
    for i in range(0, len(cx))
        if cstate[i] > 0.0
            count = count + 1

        if cstate[i] == 0.0
            draw_circle(cx[i], cy[i], 15.0)
        else if cstate[i] == 1.0
            draw_circle(cx[i], cy[i], cradius[i])
        else if cstate[i] == 2.0
            draw_circle(cx[i], cy[i], 3.0)

    draw_text("Exploded: " + str(count), 10.0, 20.0)
